      <div class="ad-compare-row"><span class="label">الصلادة</span><span class="value">8.5 موس</span></div>
      <div class="ad-compare-row"><span class="label">الكثافة</span><span class="value">3.73 غ/سم³</span></div>
    </div>
  </div>
